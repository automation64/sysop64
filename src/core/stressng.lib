#
# Imports
#

source "${S64_CORE_PATH_BL64}/bashlib64-module-bsh.bash" &&
  source "${S64_CORE_PATH_BL64}/bashlib64-module-fmt.bash" &&
  source "${S64_CORE_PATH_BL64}/bashlib64-module-xsv.bash" &&
  source "${S64_CORE_PATH_BL64}/bashlib64-module-txt.bash" &&
  source "${S64_CORE_PATH_BL64}/bashlib64-module-fs.bash" ||
  { s64_core_lib_check_bl64_load && exit 1; }

#
# Module parameters
#

# shellcheck disable=SC2034
{
  declare S64_STRESSNG_PATH_CLI="${S64_STRESSNG_PATH_CLI:-}"

  declare S64_STRESSNG_SET_PARALLEL="${S64_STRESSNG_SET_PARALLEL:-0}"
  declare S64_STRESSNG_SET_TIMEOUT="${S64_STRESSNG_SET_TIMEOUT:-10m}"
  declare S64_STRESSNG_SET_VM_BYTES="${S64_STRESSNG_SET_VM_BYTES:-80%}"
}

#
# Globals
#

# shellcheck disable=SC2034
{
  declare S64_STRESSNG_VERSION='1.1.0'
  declare S64_STRESSNG_ABOUT_MODULE_MAIN='Stress-NG Stress Test Tool'
}

#
# Functions
#

function s64_stressng_lib_setup() {
  bl64_dbg_app_show_function
  s64_core_lib_show_about "$S64_STRESSNG_ABOUT_MODULE_MAIN" &&
    s64_core_lib_command_assign 'S64_STRESSNG_PATH_CLI' 'stress-ng' &&
    bl64_msg_show_setup "$S64_CORE_LABEL_MODULE_PARAMETERS" \
      'S64_STRESSNG_SET_PARALLEL' \
      'S64_STRESSNG_SET_TIMEOUT' \
      'S64_STRESSNG_SET_VM_BYTES'
}

function s64_stressng_lib_run_stressng() {
  bl64_dbg_app_show_function "$@"
  bl64_dbg_app_trace_start
  # shellcheck disable=SC2086
  "$S64_STRESSNG_PATH_CLI" \
    "$@"
  bl64_dbg_app_trace_stop
}
