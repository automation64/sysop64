#
# Imports
#

source "${S64_CORE_PATH_BL64}/bashlib64-module-fs.bash" &&
  source "${S64_CORE_PATH_BL64}/bashlib64-module-xsv.bash" &&
  source "${S64_CORE_PATH_BL64}/bashlib64-module-fmt.bash" &&
  source "${S64_CORE_PATH_BL64}/bashlib64-module-bsh.bash" &&
  source "${S64_CORE_PATH_BL64}/bashlib64-module-txt.bash" &&
  source "${S64_CORE_PATH_BL64}/bashlib64-module-k8s.bash" ||
  { s64_core_lib_check_bl64_load && exit 1; }

#
# Module parameters
#

# shellcheck disable=SC2034
{
  declare S64_K8S_OUTPUT_FORMAT="${S64_K8S_OUTPUT_FORMAT:-yaml}"
}

#
# Globals
#

# shellcheck disable=SC2034
{
  declare S64_K8S_VERSION='4.1.0'
  declare S64_K8S_ABOUT_MODULE_MAIN='Kubernetes Platform'
  declare S64_K8S_ABOUT_SUBMODULE_CLI='Kubectl CLI'
  declare S64_K8S_ABOUT_SUBMODULE_CLT='Cluster'
  declare S64_K8S_ABOUT_SUBMODULE_NODE='Nodes'
  declare S64_K8S_ABOUT_SUBMODULE_OBJ='Objects'
  declare S64_K8S_ABOUT_SUBMODULE_SVC='Services'
  declare S64_K8S_ABOUT_SUBMODULE_WKL='Workloads'

  declare S64_K8S_PATH_CFG_KUBE="${HOME}/.kube"
  declare S64_K8S_PATH_CFG_CONFIG="${S64_K8S_PATH_CFG_KUBE}/config"
}

#
# Functions
#

function s64_k8s_lib_setup() {
  bl64_dbg_app_show_function
  s64_core_lib_show_about "$S64_K8S_ABOUT_MODULE_MAIN" &&
    bl64_k8s_setup
}

function s64_k8s_lib_cli_set_ns() {
  bl64_dbg_app_show_function "$@"
  local namespace="${1:-$BL64_VAR_DEFAULT}"
  # shellcheck disable=SC2154
  if [[ "$namespace" == "$BL64_VAR_DEFAULT" ]]; then
    printf -- '--all-namespaces'
  else
    printf -- '--namespace=%s' "${namespace}"
  fi
}

function s64_k8s_meta_strip_runtime() {
  bl64_dbg_app_show_function
  bl64_txt_run_awk '
    /^[ ]+creationTimestamp:/ { next }
    $0 == "status: {}" { next }
    { print $0 }
  '
}

function s64_k8s_lib_cli_set_format() {
  bl64_dbg_app_show_function "$@"
  local format="${1:-}"
  if [[ "$format" != 'yaml' ]]; then
    S64_K8S_OUTPUT_FORMAT="$format"
  fi
  printf -- '--output=%s' "${S64_K8S_OUTPUT_FORMAT}"
}
