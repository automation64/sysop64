#
# Imports
#

source "${S64_CORE_PATH_BL64}/bashlib64-module-bsh.bash" &&
  source "${S64_CORE_PATH_BL64}/bashlib64-module-fmt.bash" &&
  source "${S64_CORE_PATH_BL64}/bashlib64-module-xsv.bash" &&
  source "${S64_CORE_PATH_BL64}/bashlib64-module-txt.bash" &&
  source "${S64_CORE_PATH_BL64}/bashlib64-module-fs.bash" ||
  { s64_core_lib_check_bl64_load && exit 1; }

#
# Module parameters
#

# shellcheck disable=SC2034
{
  declare S64_CONTAINERD_PATH_CLI_CTR="${S64_CONTAINERD_PATH_CLI_CTR:-}"
  declare S64_CONTAINERD_PATH_CLI_CONTAINERD="${S64_CONTAINERD_PATH_CLI_CONTAINERD:-}"
  declare S64_CONTAINERD_PATH_CLI_NETDCTL="${S64_CONTAINERD_PATH_CLI_NETDCTL:-}"
}

#
# Globals
#

# shellcheck disable=SC2034
{
  declare S64_CONTAINERD_VERSION='1.0.0'
  declare S64_CONTAINERD_ABOUT_MODULE_MAIN='ContainerD - Container Runtime'

  declare S64_CONTAINERD_PATH_CFG_BASE='/etc/containerd'
  declare S64_CONTAINERD_PATH_CFG_SERVER="${S64_CONTAINERD_PATH_CFG_BASE}/config.toml"
}

#
# Functions
#

function s64_containerd_lib_setup() {
  bl64_dbg_app_show_function
  s64_core_lib_show_about "$S64_CONTAINERD_ABOUT_MODULE_MAIN" &&
    s64_core_lib_command_assign 'S64_CONTAINERD_PATH_CLI_CTR' 'ctr' &&
    s64_core_lib_command_assign 'S64_CONTAINERD_PATH_CLI_CONTAINERD' 'containerd' &&
    s64_core_lib_command_assign 'S64_CONTAINERD_PATH_CLI_NETDCTL' 'nerdctl'
}

function s64_containerd_lib_run_ctr() {
  bl64_dbg_app_show_function "$@"
  bl64_dbg_app_trace_start
  "$S64_CONTAINERD_PATH_CLI_CTR" \
    "$@"
  bl64_dbg_app_trace_stop
}

function s64_containerd_lib_run_containerd() {
  bl64_dbg_app_show_function "$@"
  bl64_dbg_app_trace_start
  "$S64_CONTAINERD_PATH_CLI_CONTAINERD" \
    "$@"
  bl64_dbg_app_trace_stop
}

function s64_containerd_lib_run_nerdctl() {
  bl64_dbg_app_show_function "$@"
  bl64_dbg_app_trace_start
  "$S64_CONTAINERD_PATH_CLI_NETDCTL" \
    "$@"
  bl64_dbg_app_trace_stop
}
