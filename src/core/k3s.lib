#
# Imports
#

source "${S64_CORE_PATH_BL64}/bashlib64-module-bsh.bash" &&
  source "${S64_CORE_PATH_BL64}/bashlib64-module-fmt.bash" &&
  source "${S64_CORE_PATH_BL64}/bashlib64-module-xsv.bash" &&
  source "${S64_CORE_PATH_BL64}/bashlib64-module-txt.bash" &&
  source "${S64_CORE_PATH_BL64}/bashlib64-module-fs.bash" ||
  { s64_core_lib_check_bl64_load && exit 1; }

#
# Module parameters
#

# shellcheck disable=SC2034
{
  declare S64_K3S_PATH_CLI="${S64_K3S_PATH_CLI:-}"
}

#
# Globals
#

# shellcheck disable=SC2034
{
  declare S64_K3S_VERSION='1.0.0'
  declare S64_K3S_ABOUT_MODULE_MAIN='K3s - Rancher Light Kubernetes'

  declare S64_K3S_PATH_CFG_K3S_SERVER='/etc/rancher/k3s/k3s.yaml'
  declare S64_K3S_PATH_AUTH_K3S_TOKEN='/var/lib/rancher/k3s/server/token'
  declare S64_K3S_PATH_CFG_K8S_KUBECTL="${HOME}/.kube/config-k3s"
}

#
# Functions
#

function s64_k3s_lib_setup() {
  bl64_dbg_app_show_function
  s64_core_lib_show_about "$S64_K3S_ABOUT_MODULE_MAIN" &&
    s64_core_lib_command_assign 'S64_K3S_PATH_CLI' 'k3s'
}

function s64_k3s_lib_run_k3s() {
  bl64_dbg_app_show_function "$@"
  bl64_dbg_app_trace_start
  "$S64_K3S_PATH_CLI" \
    "$@"
  bl64_dbg_app_trace_stop
}
